---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCategories } from "@lib/posts";

const categories = await getCategories();
---

<BaseLayout title="Categories" description="Browse posts by category." lang="zh">
  <section class="page-heading">
    <p class="eyebrow">Browse</p>
    <h1>Categories / 分类</h1>
    <p>Browse all published categories across Chinese and English posts.</p>
  </section>
  <section class="term-grid">
    {categories.map((category) => <a href={`/categories/${encodeURIComponent(category)}/`}>{category}</a>)}
  </section>
</BaseLayout>
