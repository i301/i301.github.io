---
import { render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { copy, formatDate, getOppositeLang, type Lang } from "@lib/i18n";
import { getPostUrl, getPosts, getTranslation } from "@lib/posts";

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts.map((post) => ({
    params: {
      lang: post.data.lang,
      slug: post.data.slug,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = post.data.lang as Lang;
const t = copy[lang];
const translation = await getTranslation(post);
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} lang={lang}>
  <article class="post-detail">
    <header class="post-hero">
      <a class="back-link" href={`/${lang}/`}>{t.backToPosts}</a>
      <p class="post-meta">
        <time datetime={post.data.date.toISOString()}>{t.published}: {formatDate(post.data.date, lang)}</time>
        {
          post.data.updated && (
            <time datetime={post.data.updated.toISOString()}>{t.updated}: {formatDate(post.data.updated, lang)}</time>
          )
        }
        <span>{post.data.category}</span>
      </p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="post-actions">
        {
          translation ? (
            <a href={getPostUrl(translation)}>{t.translation}</a>
          ) : (
            <a href={`/${getOppositeLang(lang)}/`}>{t.translation}</a>
          )
        }
      </div>
    </header>
    {
      post.data.cover && (
        <img class="post-cover" src={post.data.cover} alt="" loading="eager" />
      )
    }
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
