---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getTags } from "@lib/posts";

const tags = await getTags();
---

<BaseLayout title="Tags" description="Browse AI research notes by tag." lang="zh">
  <section class="page-heading simple-heading">
    <p class="eyebrow">Browse</p>
    <h1>Tags / 标签</h1>
    <p>按公司、模型、工具和方法论快速进入相关研究笔记。</p>
  </section>
  <section class="term-grid">
    {tags.map((tag) => <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
  </section>
</BaseLayout>
