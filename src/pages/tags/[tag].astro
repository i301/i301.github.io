---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import { getPosts, getTags, type Post } from "@lib/posts";

export async function getStaticPaths() {
  const tags = await getTags();

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const posts = (await getPosts()).filter((post) => post.data.tags.includes(tag));
---

<BaseLayout title={`Tag: ${tag}`} description={`Posts tagged ${tag}.`} lang="zh">
  <section class="page-heading">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
  </section>
  <section class="post-list">
    {posts.map((post: Post) => <PostCard post={post} lang={post.data.lang} />)}
  </section>
</BaseLayout>
