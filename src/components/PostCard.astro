---
import { formatDate, type Lang } from "@lib/i18n";
import { getPostUrl, type Post } from "@lib/posts";

interface Props {
  post: Post;
  lang: Lang;
}

const { post, lang } = Astro.props;
---

<article class="post-card">
  <a class="post-card__cover" href={getPostUrl(post)} aria-label={post.data.title}>
    {
      typeof post.data.cover === "string" ? (
        <img src={post.data.cover} alt="" loading="lazy" />
      ) : (
        <div class="post-card__cover-placeholder" aria-hidden="true"></div>
      )
    }
  </a>
  <div class="post-card__body">
    <p class="post-card__meta">
      <span>{post.data.category}</span>
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, lang)}</time>
    </p>
    <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
  </div>
</article>
