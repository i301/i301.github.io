---
import { copy, formatDate, type Lang } from "@lib/i18n";
import { getPostUrl, type Post } from "@lib/posts";
import PostCard from "./PostCard.astro";

interface Props {
  lang: Lang;
  posts: Post[];
}

const { lang, posts } = Astro.props;
const t = copy[lang];
const featured = posts[0];
const listPosts = featured ? posts.slice(1) : posts;
---

<section class="ai-hero" aria-labelledby="home-title">
  <p class="eyebrow">{t.archive}</p>
  <h1 id="home-title">{t.latestPosts}</h1>
  <p>{t.siteDescription}</p>
</section>

{
  featured && (
    <section class="featured-article" aria-labelledby="featured-title">
      <a class="featured-article__visual" href={getPostUrl(featured)} aria-label={featured.data.title}>
        {featured.data.cover && <img src={featured.data.cover} alt="" loading="eager" />}
      </a>
      <div class="featured-article__body">
        <p class="post-card__meta">
          <span>{featured.data.category}</span>
          <time datetime={featured.data.date.toISOString()}>{formatDate(featured.data.date, lang)}</time>
        </p>
        <h2 id="featured-title">
          <a href={getPostUrl(featured)}>{featured.data.title}</a>
        </h2>
        <p>{featured.data.description}</p>
        <a class="read-link" href={getPostUrl(featured)}>{t.readMore}</a>
      </div>
    </section>
  )
}

<section class="article-index" aria-label={t.allPosts}>
  <div class="section-heading">
    <p class="eyebrow">{t.allPosts}</p>
  </div>
  <div class="post-list">
    {
      listPosts.length > 0 ? (
        listPosts.map((post) => <PostCard post={post} lang={lang} />)
      ) : (
        <p class="empty-state">{t.noPosts}</p>
      )
    }
  </div>
</section>
